# aju server to benchmark against
AJU_BASE_URL=https://aju.sh
# Bearer token (aju_live_... or aju_test_...)
AJU_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANSWERER_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5-20251001

# Retrieval knobs (deep-search)
SEEDS=5
LIMIT=15
DEPTH=1

# Run identity — used to namespace brains and output files
RUN_ID=run-01
