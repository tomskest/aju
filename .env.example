# ---------- Runtime ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_URL=http://localhost:3000

# MCP endpoint shown in onboarding + docs. Production: https://mcp.aju.sh/mcp.
# Override for local dev / staging. If unset, defaults to the production URL.
NEXT_PUBLIC_MCP_URL=http://localhost:3000/api/mcp

# ---------- Database: control plane ----------
# DATABASE_URL is the DIRECT (non-pooled) DSN for the aju_control database.
# Used by Prisma CLI for migrations and DDL. In local dev this can be the
# docker-compose Postgres.
DATABASE_URL=postgresql://aju:aju_dev@localhost:5433/aju

# CONTROL_POOLED_URL is the PgBouncer (transaction mode) DSN for runtime
# queries against the control DB on Neon. Append ?pgbouncer=true in prod.
# Leave unset in local dev — the app falls back to DATABASE_URL.
CONTROL_POOLED_URL=

# ---------- Database: tenant plane (per-org DBs) ----------
# Neon project that hosts the tenant DBs. Used by src/lib/tenant-provision.ts
# to create a new database + role per org via the Neon HTTP API.
NEON_API_KEY=
NEON_PROJECT_ID=

# AES-GCM key used to encrypt the per-tenant DSNs stored in the tenant table.
# Generate with: openssl rand -base64 32
TENANT_DSN_ENC_KEY=

# Local-dev escape hatch. When set to 1, tenantDbFor() returns a single
# PrismaClient pointed at DATABASE_URL, and the tenant schema is applied to
# the control DB alongside the control schema. Never set in production.
USE_LOCAL_TENANT_DB=1

# LRU cache ceiling for cached tenant Prisma clients. Each client holds
# ~30-50 MB plus a connection pool. Tune to RAM headroom.
TENANT_CLIENT_CACHE_MAX=30

# ---------- Object storage ----------
# Per-tenant Tigris buckets. Runtime operations (get/put/delete against the
# tenant bucket) use per-tenant scoped keys decrypted from the tenant row.
# Bucket + scoped-key PROVISIONING happens at signup time if the
# TIGRIS_STORAGE_* admin creds below are set; otherwise you're in
# operator-led mode (run scripts/provision-tigris-bucket.ts by hand).

# AES-GCM key for encrypting per-tenant Tigris access keys stored on the
# tenant row. Generate with: openssl rand -base64 32
STORAGE_CRED_ENC_KEY=

# Admin-role Tigris access key for auto-provisioning new tenants on signup.
# Must carry the `--admin` role assignment so it can CreateBucket and mint
# new scoped access keys. Mint once with an operator OAuth session:
#   tigris access-keys create aju-railway-admin
#   tigris access-keys assign <id> --admin
# Leave both unset to disable auto-provisioning — new tenants land without
# a storage bucket and fall back to the AWS_* shared bucket until someone
# runs scripts/provision-tigris-bucket.ts for them.
TIGRIS_STORAGE_ACCESS_KEY_ID=
TIGRIS_STORAGE_SECRET_ACCESS_KEY=

# Optional: overrides for the S3-compatible endpoint and region applied to
# every per-tenant client. Leave unset to use Tigris defaults
# (endpoint=https://t3.storage.dev, region=auto). `region` here is only used
# for SigV4 request signing and is independent of where bucket data lives —
# data residency is a per-bucket property set at provisioning time.
STORAGE_ENDPOINT_URL=
STORAGE_REGION=

# Operator-only: data-residency PoP(s) for newly provisioned buckets. Passed
# through to `tigris mk --locations` by scripts/provision-tigris-bucket.ts.
# Defaults to `fra` (Frankfurt) — single-PoP EU residency for GDPR with no
# multi-region cost overhead. Override to `fra,ams` for in-EU redundancy, or
# `global` for default replicated buckets. Valid single-region codes: ams,
# fra, gru, iad, jnb, lhr, nrt, ord, sin, sjc, syd. Not read by the app
# runtime.
TIGRIS_BUCKET_LOCATIONS=fra

# ---------- Legacy shared-bucket fallback (transitional) ----------
# src/lib/tenant-storage.ts falls back to these when a tenant row has no
# storageBucket yet. Remove once scripts/provision-tigris-bucket.ts --all has
# run against prod and every active tenant row has storage columns populated.
AWS_ENDPOINT_URL=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# ---------- Auth ----------
BETTER_AUTH_SECRET=change-me-with-openssl-rand-base64-32
EMAIL_FROM=hello@aju.sh

# ---------- External providers ----------
OPENAI_API_KEY=
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---------- Rate limiting / cron ----------
# CRON_SECRET — gate /api/cron/* endpoints. Generate with: openssl rand -base64 32
CRON_SECRET=

# OAUTH_DEBUG — set to "1" to enable per-request logger in src/middleware.ts.
OAUTH_DEBUG=

# ---------- Optional ----------
# SENTRY_DSN=

# ---------- Observability ----------
# LOG_LEVEL — one of "trace" | "debug" | "info" | "warn" | "error". Defaults to
# "debug" in dev and "info" in production.
LOG_LEVEL=

# ---------- Backups ----------
# Backups — set to enable scripts/pg-dump-to-s3.ts
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups
BACKUP_S3_KMS_KEY_ID=
