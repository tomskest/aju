{
  "name": "aju",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && next build",
    "start": "prisma migrate deploy --schema data/control/schema.prisma && tsx scripts/tenant-migrate.ts && next start",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "prisma generate --schema data/control/schema.prisma && prisma generate --schema data/tenant/schema.prisma",
    "mcp:aju": "npx tsx client/mcp/aju-server.ts",
    "db:migrate:control": "prisma migrate dev --schema data/control/schema.prisma",
    "db:push:control": "prisma db push --schema data/control/schema.prisma",
    "db:migrate:tenant": "tsx scripts/tenant-migrate.ts",
    "db:migrate:baseline:control": "prisma migrate resolve --schema data/control/schema.prisma --applied 20260422000000_init",
    "db:migrate:deploy:control": "prisma migrate deploy --schema data/control/schema.prisma",
    "db:migrate:status:control": "prisma migrate status --schema data/control/schema.prisma",
    "db:provision:sweep": "tsx scripts/provision-existing-orgs.ts",
    "kill:app": "npx tsx scripts/kill-app.ts",
    "backfill:embeddings": "npx tsx scripts/backfill-embeddings.ts",
    "backup:pg-dump": "tsx scripts/pg-dump-to-s3.ts",
    "lint": "eslint src client/mcp",
    "lint:fix": "eslint src client/mcp --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@aws-sdk/client-s3": "^3.992.0",
    "@aws-sdk/lib-storage": "^3.992.0",
    "@aws-sdk/s3-request-presigner": "^3.992.0",
    "@modelcontextprotocol/sdk": "^1",
    "@prisma/client": "^6.19.3",
    "@tigrisdata/cli": "^2.17.0",
    "diff": "^8.0.3",
    "gray-matter": "^4",
    "marked": "^16.4.2",
    "mermaid": "^11.14.0",
    "next": "^15",
    "node-diff3": "^3.2.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8",
    "pino": "^9",
    "prisma": "^6",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/diff": "^7.0.2",
    "@types/node": "^22",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^2",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "eslint-config-prettier": "^9",
    "pino-pretty": "^11",
    "postcss": "^8.5.10",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "tailwindcss": "^4.2.2",
    "tsx": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5",
    "vitest": "^2"
  }
}
