{
  "name": "@aju/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the aju HTTP API. Generated from client/openapi/openapi.yaml.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist src/generated",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
